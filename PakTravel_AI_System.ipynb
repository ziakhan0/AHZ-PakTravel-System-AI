    "# ============================================================\n",
    "# TASK 2: Backtracking Search + MRV Heuristic\n",
    "# Backtracking: try each bus for each route, backtrack on conflict\n",
    "# MRV: pick route with Minimum Remaining Values (fewest options) first\n",
    "# ============================================================\n",
    "\n",
    "def is_consistent(route, bus, assignment, conflicts):\n",
    " \"\"\"\n",
    " Check if assigning 'bus' to 'route' is consistent with current assignment.\n",
    " A bus cannot be used for two routes that conflict (same time).\n",
    " Also enforces max 2 routes per bus.\n",
    " \"\"\"\n",
    " # Check time conflict: no same bus at same time\n",
    " for r1, r2 in conflicts:\n",
    " if r1 == route and r2 in assignment and assignment[r2] == bus:\n",
    " return False\n",
    " if r2 == route and r1 in assignment and assignment[r1] == bus:\n",
    " return False\n",
    "\n",
    " # Check max 2 routes per bus\n",
    " bus_count = sum(1 for v in assignment.values() if v == bus)\n",
    " if bus_count >= 2:\n",
    " return False\n",
    "\n",
    " return True\n",
    "\n",
    "\n",
    "def plain_backtracking(routes, buses, conflicts, domains=None, call_count=[0]):\n",
    " \"\"\"\n",
    " Plain backtracking CSP solver.\n",
    " Tries buses in order for each route (no heuristic).\n",
    " \"\"\"\n",
    " assignment = {}\n",
    " call_count[0] = 0\n",
    "\n",
    " def backtrack(assignment):\n",
    " call_count[0] += 1\n",
    "\n",
    " if len(assignment) == len(routes): # All routes assigned\n",
    " return assignment\n",
    "\n",
    " # Pick next unassigned route (plain order)\n",
    " unassigned = [r for r in routes if r not in assignment]\n",
    " route = unassigned[0]\n",
    "\n",
    " # Try each bus in domain\n",
    " bus_list = domains[route] if domains else buses\n",
    " for bus in bus_list:\n",
    " if is_consistent(route, bus, assignment, conflicts):\n",
    " assignment[route] = bus\n",
    " result = backtrack(assignment)\n",
    " if result:\n",
    " return result\n",
    " del assignment[route] # Backtrack\n",
    "\n",
    " return None # No valid assignment found\n",
    "\n",
    " return backtrack(assignment), call_count[0]\n",
    "\n",
    "\n",
    "def mrv_backtracking(routes, buses, conflicts, domains=None, call_count=[0]):\n",
    " \"\"\"\n",
    " Backtracking with MRV heuristic.\n",
    " Always picks the route with fewest remaining valid bus options.\n",
    " \"\"\"\n",
    " call_count[0] = 0\n",
    "\n",
    " def get_remaining_values(route, assignment, domain):\n",
    " \"\"\"Count valid buses remaining for this route.\"\"\"\n",
    " return sum(1 for bus in domain\n",
    " if is_consistent(route, bus, assignment, conflicts))\n",
    "\n",
    " def backtrack(assignment):\n",
    " call_count[0] += 1\n",
    "\n",
    " if len(assignment) == len(routes):\n",
    " return assignment\n",
    "\n",
    " unassigned = [r for r in routes if r not in assignment]\n",
    "\n",
    " # MRV: pick route with minimum remaining valid values\n",
    " bus_list_fn = lambda r: domains[r] if domains else buses\n",
    " route = min(unassigned,\n",
    " key=lambda r: get_remaining_values(r, assignment, bus_list_fn(r)))\n",
    "\n",
    " for bus in (domains[route] if domains else buses):\n",
    " if is_consistent(route, bus, assignment, conflicts):\n",
    " assignment[route] = bus\n",
    " result = backtrack(assignment)\n",
    " if result:\n",
    " return result\n",
    " del assignment[route]\n",
    "\n",
    " return None\n",
    "\n",
    " return backtrack({}), call_count[0]\n",
    "\n",
    "\n",
    "route_names = list(ROUTES.keys())\n",
    "\n",
    "# Run plain backtracking\n",
    "bt_solution, bt_calls = plain_backtracking(route_names, BUSES, CONFLICTS)\n",
    "\n",
    "# Run MRV backtracking\n",
    "mrv_solution, mrv_calls = mrv_backtracking(route_names, BUSES, CONFLICTS)\n",
    "\n",
    "def print_schedule(solution, title):\n",
    " \"\"\"Print bus schedule in formatted table.\"\"\"\n",
    " print(f\"\\n{title}\")\n",
    " print(\"-\" * 60)\n",
    " print(f\" {'Route':<5} {'Description':<30} {'Bus':<8} {'Time':<6} Status\")\n",
    " print(\"-\" * 60)\n",
    " for route in route_names:\n",
    " bus = solution.get(route, 'NONE')\n",
    " info = ROUTES[route]\n",
    " flag = \" ALI'S BUS\" if route == 'R3' else \"\"\n",
    " print(f\" {route:<5} {info['name']:<30} {bus:<8} {info['time']:<6} {flag}\")\n",
