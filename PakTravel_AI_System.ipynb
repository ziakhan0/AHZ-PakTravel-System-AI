    "# ============================================================\n",
    "# TASK 4: Relay Route Planner\n",
    "# Finds best 2-leg journey: start → relay_city → destination\n",
    "# Tries all valid relay points and picks minimum total distance\n",
    "# ============================================================\n",
    "\n",
    "def find_relay_route(start, destination, relay_points, graph):\n",
    " \"\"\"\n",
    " Finds the best 2-leg relay journey.\n",
    " Tries every relay point as intermediate stop.\n",
    " Returns: (best_relay, leg1_path, leg1_dist, leg2_path, leg2_dist, total_dist)\n",
    " \"\"\"\n",
    " best_total = float('inf')\n",
    " best_result = None\n",
    "\n",
    " for relay in relay_points:\n",
    " # Skip if relay is same as start or destination\n",
    " if relay == start or relay == destination:\n",
    " continue\n",
    "\n",
    " # Find leg 1: start → relay\n",
    " path1, dist1, _ = ucs(graph, start, relay)\n",
    " # Find leg 2: relay → destination\n",
    " path2, dist2, _ = ucs(graph, relay, destination)\n",
    "\n",
    " # Check if both legs have valid paths\n",
    " if path1 and path2:\n",
    " total = dist1 + dist2\n",
    " if total < best_total:\n",
    " best_total = total\n",
    " best_result = (relay, path1, dist1, path2, dist2, total)\n",
    "\n",
    " return best_result\n",
    "\n",
    "\n",
    "def print_relay_result(start, destination, relay_points, graph):\n",
    " \"\"\"Print relay route result with comparison to direct route.\"\"\"\n",
    " print(f\"\\n Relay Journey: {start} → [RELAY] → {destination}\")\n",
