    "# ============================================================\n# TASK 1: Build the Knowledge Base using aima3\n# PropDefiniteKB stores Horn clauses (definite clauses)\n# kb.tell(expr('...'))  adds rules/facts\n# pl_fc_entails(kb, expr('...'))  runs forward chaining\n# ============================================================\n\n# Create the knowledge base\nkb = PropDefiniteKB()\n\n# ---- 15 Traffic Law Rules ----\n# Format: kb.tell(expr('condition ==> conclusion'))\n# AND conditions: kb.tell(expr('(A & B) ==> C'))\n\nTRAFFIC_RULES = [\n    # (rule_expr_string, readable_text)\n    ('No_Helmet ==> Fine_500',\n     'Rule 1 : IF No_Helmet          THEN Fine_500'),\n\n    ('No_Seatbelt ==> Fine_1000',\n     'Rule 2 : IF No_Seatbelt         THEN Fine_1000'),\n\n    ('Speed_Above_Limit ==> Challan_Issued',\n     'Rule 3 : IF Speed_Above_Limit   THEN Challan_Issued'),\n\n    ('(Challan_Issued & Not_Paid) ==> License_Suspended',\n     'Rule 4 : IF Challan_Issued AND Not_Paid      THEN License_Suspended'),\n\n    ('(License_Suspended & Still_Driving) ==> Arrested',\n     'Rule 5 : IF License_Suspended AND Still_Driving THEN Arrested'),\n\n    ('(Accident & No_Insurance) ==> Court_Case',\n     'Rule 6 : IF Accident AND No_Insurance        THEN Court_Case'),\n\n    ('(Court_Case & Found_Guilty) ==> License_Cancelled',\n     'Rule 7 : IF Court_Case AND Found_Guilty      THEN License_Cancelled'),\n\n    ('No_License ==> Heavy_Fine_5000',\n     'Rule 8 : IF No_License          THEN Heavy_Fine_5000'),\n\n    ('Mobile_While_Driving ==> Fine_2000',\n     'Rule 9 : IF Mobile_While_Driving THEN Fine_2000'),\n\n    ('Red_Light ==> Fine_1500',\n     'Rule 10: IF Red_Light            THEN Fine_1500'),\n\n    ('Fine_Paid_7Days ==> Discount_50_Percent',\n     'Rule 11: IF Fine_Paid_7Days      THEN Discount_50_Percent'),\n\n    ('Three_Violations ==> License_Suspended',\n     'Rule 12: IF Three_Violations     THEN License_Suspended'),\n\n    ('License_Suspended ==> Cannot_Drive_Legally',\n     'Rule 13: IF License_Suspended    THEN Cannot_Drive_Legally'),\n\n    ('Drunk_Driving ==> Arrested_Immediately',\n     'Rule 14: IF Drunk_Driving        THEN Arrested_Immediately'),\n\n    ('(Arrested & Repeat_Offender) ==> Jail_Term',\n     'Rule 15: IF Arrested AND Repeat_Offender     THEN Jail_Term'),\n]\n\n# Tell all 15 rules to the KB using aima3 expr()\nfor rule_str, _ in TRAFFIC_RULES:\n    kb.tell(expr(rule_str))\n\n\ndef show_laws():\n    \"\"\"Print all 15 traffic laws in readable IF...THEN format.\"\"\"\n    print(\"\\n  PakTravel AI Legal Advisor — Traffic Laws KB\")\n    print(\"=\" * 60)\n    for _, readable in TRAFFIC_RULES:\n        print(f\"   {readable}\")\n    print(\"=\" * 60)\n\nshow_laws()\n\n# ---- Tell Ahmed's Facts to the KB ----\nahmed_facts = [\n    'Speed_Above_Limit',    # Ahmed was speeding\n    'Mobile_While_Driving', # Ahmed was using phone while driving\n    'Not_Paid',             # Challans not paid\n    'Three_Violations',     # Already 3 violations this month\n    'Repeat_Offender',      # He is a repeat offender\n    'Still_Driving',        # Was still driving despite suspension\n]\n\nprint(\"\\n  Ahmed's Known Facts (told to KB):\")\nfor fact in ahmed_facts:\n    kb.tell(expr(fact))          # <-- aima3: tell each fact\n    print(f\"   kb.tell(expr('{fact}'))\")\n\n# ---- Query the KB using pl_fc_entails (Forward Chaining) ----\nprint(\"\\n  KB Queries using pl_fc_entails (Forward Chaining):\")\nprint(\"-\" * 50)\n\nlic_suspended = pl_fc_entails(kb, expr('License_Suspended'))\nis_arrested   = pl_fc_entails(kb, expr('Arrested'))\njail_term     = pl_fc_entails(kb, expr('Jail_Term'))\n\nprint(f\"   Is License Suspended? --> {'YES' if lic_suspended else 'NO'}\")\nprint(f\"   Is Ahmed Arrested?    --> {'YES' if is_arrested   else 'NO'}\")\nprint(f\"   Jail Term?            --> {'YES' if jail_term     else 'NO'}\")\n\n# ---- Calculate Total Fines ----\nfine_map = {\n    'Fine_500':        500,\n    'Fine_1000':      1000,\n    'Fine_2000':      2000,\n    'Fine_1500':      1500,\n    'Heavy_Fine_5000': 5000,\n}\ntotal_fine = sum(\n    amount for fact, amount in fine_map.items()\n    if pl_fc_entails(kb, expr(fact))\n)\nprint(f\"\\n  Total Fines Ahmed Must Pay: Rs. {total_fine:,}\")\n\nprint(\"\\n  All Derived Consequences:\")\nconsequences = [\n    'Challan_Issued', 'License_Suspended', 'Cannot_Drive_Legally',\n    'Arrested', 'Jail_Term', 'Fine_2000'\n]\nfor c in consequences:\n    result = pl_fc_entails(kb, expr(c))\n    print(f\"   {c:<25} --> {'YES' if result else 'NO'}\")\n"
