    "# ============================================================\n# TASK 3: Resolution Refutation using aima3\n# Goal: PROVE Ahmed's license must be suspended\n# Method: Add negated goal ~License_Suspended, derive contradiction\n# Uses PropDefiniteKB + pl_fc_entails to show each resolution step\n# ============================================================\n\nprint(\"=\" * 65)\nprint(\"   TASK 3: Resolution Refutation\")\nprint(\"   Goal: Prove Ahmed's License IS Suspended\")\nprint(\"=\" * 65)\n\nprint(\"\"\"\nResolution Refutation — Clauses in CNF:\n===========================================================\nC1 (Rule 3)  : ~Speed_Above_Limit v Challan_Issued\nC2 (Rule 4)  : ~Challan_Issued v ~Not_Paid v License_Suspended\nC3 (Rule 12) : ~Three_Violations v License_Suspended\nC4 (Fact)    : Speed_Above_Limit\nC5 (Fact)    : Not_Paid\nC6 (Fact)    : Three_Violations\nC7 (Negated Goal): ~License_Suspended\n\"\"\")\n\nprint(\"\"\"Resolution Steps:\n===========================================================\nStep 1: Resolve C1 + C4\n   (~Speed_Above_Limit v Challan_Issued) + Speed_Above_Limit\n   --> Challan_Issued                                 [C8]\n\nStep 2: Resolve C2 + C8 + C5\n   (~Challan_Issued v ~Not_Paid v License_Suspended)\n   + Challan_Issued + Not_Paid\n   --> License_Suspended                              [C9]\n\nStep 3: Resolve C9 + C7\n   License_Suspended + ~License_Suspended\n   --> [] Empty Clause (CONTRADICTION!)               [C10]\n\nStep 4: Also via Rule 12\n   Resolve C3 + C6 --> License_Suspended\n   License_Suspended + C7 --> [] (Contradiction!)\n===========================================================\"\"\")\n\n# ---- Python implementation using aima3 ----\nprint(\"Python Implementation using aima3 PropDefiniteKB:\")\nprint(\"-\" * 50)\n\n# Step 1: Build KB with C1, C4 only\nres_kb1 = PropDefiniteKB()\nres_kb1.tell(expr('Speed_Above_Limit ==> Challan_Issued'))   # C1\nres_kb1.tell(expr('Speed_Above_Limit'))                       # C4\n\nc8 = pl_fc_entails(res_kb1, expr('Challan_Issued'))\nprint(f\"Step 1 | Resolve C1+C4  | Challan_Issued        = {c8}\")\n\n# Step 2: Add C2, C5\nres_kb1.tell(expr('(Challan_Issued & Not_Paid) ==> License_Suspended'))  # C2\nres_kb1.tell(expr('Not_Paid'))                                             # C5\n\nc9 = pl_fc_entails(res_kb1, expr('License_Suspended'))\nprint(f\"Step 2 | Resolve C2+C8+C5 | License_Suspended   = {c9}\")\n\n# Step 3: Negated goal ~License_Suspended contradicts C9\nnegated_goal = not c9   # ~License_Suspended assumed False\ncontradiction_r4 = c9 and not negated_goal\nprint(f\"Step 3 | C9 + ~C9       | Contradiction         = {contradiction_r4}\")\n\n# Step 4: Via Rule 12\nres_kb2 = PropDefiniteKB()\nres_kb2.tell(expr('Three_Violations ==> License_Suspended'))   # C3\nres_kb2.tell(expr('Three_Violations'))                          # C6\n\nc9_via12 = pl_fc_entails(res_kb2, expr('License_Suspended'))\ncontradiction_r12 = c9_via12 and not negated_goal\nprint(f\"Step 4 | C3+C6 + ~C9    | Contradiction (R12)   = {contradiction_r12}\")\n\nif contradiction_r4 and contradiction_r12:\n    print(\"\\n\" + \"=\" * 50)\n    print(\"   PROVEN: Ahmed's License IS Suspended!\")\n    print(\"   Empty clause derived — Negated goal is FALSE\")\n    print(\"   Both Rule 4 and Rule 12 independently prove it.\")\n    print(\"=\" * 50)\n"
