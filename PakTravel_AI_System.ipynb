    "print(f\" MRV Backtracking calls : {mrv_calls}\")\n",
    "print(f\" Improvement : {bt_calls - mrv_calls} fewer calls with MRV\")\n",
    "\n",
    "ali_bus = mrv_solution.get('R3', 'NONE')\n",
    "print(f\"\\n Ali's connecting bus is {ali_bus} at 12pm \")"
   ]
