    " direct_path, direct_dist, _ = ucs(graph, start, destination)\n",
    " print(f\" Direct Route : {' → '.join(direct_path)} ({direct_dist} km)\")\n",
    " diff = total - direct_dist\n",
    " if diff > 0:\n",
    " print(f\" Relay adds {diff} km extra vs direct\")\n",
    " else:\n",
    " print(f\" Relay is same distance as direct\")\n",
    " else:\n",
    " print(\" No relay route found!\")\n",
    "\n",
    "\n",
