    "# ============================================================\n",
    "# TASK 5: Bidirectional Search + Full Comparison + Network Plot\n",
    "# Bidirectional: search from both start and goal simultaneously\n",
    "# ============================================================\n",
    "\n",
    "def bidirectional_search(graph, start, goal):\n",
    " \"\"\"\n",
    " Bidirectional UCS — searches from both ends simultaneously.\n",
    " Stops when the two frontiers meet.\n",
    " Returns: (path, total_distance, nodes_explored)\n",
    " \"\"\"\n",
    " # Forward frontier: from start\n",
    " fwd_frontier = [(0, start, [start])]\n",
    " # Backward frontier: from goal\n",
    " bwd_frontier = [(0, goal, [goal])]\n",
    "\n",
    " fwd_visited = {start: (0, [start])} # node: (cost, path)\n",
    " bwd_visited = {goal: (0, [goal])}\n",
    "\n",
    " nodes_explored = 0\n",
    " best_cost = float('inf')\n",
    " best_path = None\n",
    "\n",
    " while fwd_frontier or bwd_frontier:\n",
    " # Expand forward frontier\n",
    " if fwd_frontier:\n",
    " cost, node, path = heapq.heappop(fwd_frontier)\n",
    " nodes_explored += 1\n",
    "\n",
    " if node in bwd_visited: # Frontiers met!\n",
    " bwd_cost, bwd_path = bwd_visited[node]\n",
    " total = cost + bwd_cost\n",
    " if total < best_cost:\n",
    " best_cost = total\n",
    " best_path = path + list(reversed(bwd_path[:-1]))\n",
    "\n",
    " for neighbor, dist in graph.get(node, []):\n",
    " new_cost = cost + dist\n",
    " if neighbor not in fwd_visited or new_cost < fwd_visited[neighbor][0]:\n",
    " fwd_visited[neighbor] = (new_cost, path + [neighbor])\n",
    " heapq.heappush(fwd_frontier, (new_cost, neighbor, path + [neighbor]))\n",
    "\n",
    " # Expand backward frontier\n",
    " if bwd_frontier:\n",
    " cost, node, path = heapq.heappop(bwd_frontier)\n",
    " nodes_explored += 1\n",
    "\n",
    " if node in fwd_visited:\n",
    " fwd_cost, fwd_path = fwd_visited[node]\n",
    " total = cost + fwd_cost\n",
    " if total < best_cost:\n",
    " best_cost = total\n",
    " best_path = fwd_path + list(reversed(path[:-1]))\n",
    "\n",
    " for neighbor, dist in graph.get(node, []):\n",
    " new_cost = cost + dist\n",
    " if neighbor not in bwd_visited or new_cost < bwd_visited[neighbor][0]:\n",
    " bwd_visited[neighbor] = (new_cost, path + [neighbor])\n",
    " heapq.heappush(bwd_frontier, (new_cost, neighbor, path + [neighbor]))\n",
    "\n",
    " if best_path:\n",
    " break\n",
    "\n",
    " return best_path, best_cost, nodes_explored\n",
    "\n",
    "\n",
    "# ---- Run all 3 algorithms on Karachi → Islamabad ----\n",
    "start_city, goal_city = 'Karachi', 'Islamabad'\n",
    "\n",
    "t0 = time.time(); ucs_p, ucs_d, ucs_n = ucs(road_graph, start_city, goal_city); ucs_t = round(time.time()-t0, 6)\n",
    "t0 = time.time(); ast_p, ast_d, ast_n = astar(road_graph, start_city, goal_city, HEURISTIC); ast_t = round(time.time()-t0, 6)\n",
    "t0 = time.time(); bid_p, bid_d, bid_n = bidirectional_search(road_graph, start_city, goal_city); bid_t = round(time.time()-t0, 6)\n",
