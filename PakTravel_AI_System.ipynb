    "# ============================================================\n",
    "# TASK 4: ANN from Scratch — NumPy Only\n",
    "# Architecture: 5 → 10 → 8 → 1\n",
    "# Implements: Weight init, Forward prop, Sigmoid, BCE Loss,\n",
    "# Backpropagation, Gradient Descent\n",
    "# ============================================================\n",
    "\n",
    "class NumpyANN:\n",
    " \"\"\"\n",
    " Fully connected ANN built from scratch using only NumPy.\n",
    " Architecture: input(5) → hidden1(10, ReLU) → hidden2(8, ReLU) → output(1, Sigmoid)\n",
    " \"\"\"\n",
    "\n",
    " def __init__(self, input_size=5, h1=10, h2=8, output=1, lr=0.01):\n",
    " \"\"\"Initialize weights and biases randomly.\"\"\"\n",
    " self.lr = lr # Learning rate\n",
    "\n",
    " # Xavier initialization for better convergence\n",
    " self.W1 = np.random.randn(input_size, h1) * np.sqrt(2.0/input_size)\n",
    " self.b1 = np.zeros((1, h1))\n",
    "\n",
    " self.W2 = np.random.randn(h1, h2) * np.sqrt(2.0/h1)\n",
    " self.b2 = np.zeros((1, h2))\n",
    "\n",
    " self.W3 = np.random.randn(h2, output) * np.sqrt(2.0/h2)\n",
    " self.b3 = np.zeros((1, output))\n",
    "\n",
    " def sigmoid(self, z):\n",
    " \"\"\"Sigmoid activation: 1 / (1 + e^-z)\"\"\"\n",
    " return 1.0 / (1.0 + np.exp(-np.clip(z, -500, 500)))\n",
    "\n",
    " def relu(self, z):\n",
    " \"\"\"ReLU activation: max(0, z)\"\"\"\n",
    " return np.maximum(0, z)\n",
    "\n",
    " def relu_deriv(self, z):\n",
    " \"\"\"Derivative of ReLU: 1 if z>0 else 0\"\"\"\n",
    " return (z > 0).astype(float)\n",
    "\n",
    " def forward(self, X):\n",
    " \"\"\"Forward propagation through all layers.\"\"\"\n",
    " # Layer 1: Hidden 1 (ReLU)\n",
    " self.z1 = X.dot(self.W1) + self.b1\n",
    " self.a1 = self.relu(self.z1)\n",
    "\n",
    " # Layer 2: Hidden 2 (ReLU)\n",
    " self.z2 = self.a1.dot(self.W2) + self.b2\n",
    " self.a2 = self.relu(self.z2)\n",
    "\n",
    " # Output Layer: Sigmoid\n",
    " self.z3 = self.a2.dot(self.W3) + self.b3\n",
    " self.a3 = self.sigmoid(self.z3)\n",
    "\n",
    " return self.a3\n",
    "\n",
    " def binary_cross_entropy(self, y_true, y_pred):\n",
    " \"\"\"Binary Cross Entropy Loss: -[y*log(p) + (1-y)*log(1-p)]\"\"\"\n",
    " eps = 1e-9 # Avoid log(0)\n",
    " return -np.mean(\n",
    " y_true * np.log(y_pred + eps) + (1 - y_true) * np.log(1 - y_pred + eps)\n",
    " )\n",
    "\n",
    " def backward(self, X, y_true):\n",
    " \"\"\"Backpropagation — compute gradients and update weights.\"\"\"\n",
    " m = X.shape[0] # Number of samples\n",
    "\n",
    " # Output layer gradient\n",
    " dL_da3 = self.a3 - y_true.reshape(-1, 1) # dLoss/dOutput\n",
    "\n",
    " # Gradient for W3 and b3\n",
    " dW3 = self.a2.T.dot(dL_da3) / m\n",
    " db3 = np.sum(dL_da3, axis=0, keepdims=True) / m\n",
    "\n",
    " # Backprop through hidden layer 2\n",
    " da2 = dL_da3.dot(self.W3.T)\n",
    " dz2 = da2 * self.relu_deriv(self.z2)\n",
    " dW2 = self.a1.T.dot(dz2) / m\n",
    " db2 = np.sum(dz2, axis=0, keepdims=True) / m\n",
    "\n",
    " # Backprop through hidden layer 1\n",
    " da1 = dz2.dot(self.W2.T)\n",
    " dz1 = da1 * self.relu_deriv(self.z1)\n",
    " dW1 = X.T.dot(dz1) / m\n",
    " db1 = np.sum(dz1, axis=0, keepdims=True) / m\n",
    "\n",
    " # Gradient descent weight update\n",
    " self.W3 -= self.lr * dW3\n",
    " self.b3 -= self.lr * db3\n",
    " self.W2 -= self.lr * dW2\n",
    " self.b2 -= self.lr * db2\n",
    " self.W1 -= self.lr * dW1\n",
    " self.b1 -= self.lr * db1\n",
    "\n",
    " def train(self, X, y, epochs=100):\n",
    " \"\"\"Train the ANN for specified number of epochs.\"\"\"\n",
    " losses = []\n",
    " for epoch in range(1, epochs+1):\n",
    " y_pred = self.forward(X) # Forward pass\n",
    " loss = self.binary_cross_entropy(y, y_pred) # Compute loss\n",
    " self.backward(X, y) # Backprop + update\n",
    " losses.append(loss)\n",
    "\n",
    " # Print loss every 20 epochs\n",
    " if epoch % 20 == 0 or epoch == 1:\n",
    " print(f\" Epoch {epoch:>3} | Loss: {loss:.6f}\")\n",
    "\n",
    " return losses\n",
    "\n",
    " def predict(self, X, threshold=0.5):\n",
    " \"\"\"Predict class labels (0 or 1) based on threshold.\"\"\"\n",
    " return (self.forward(X) >= threshold).astype(int).flatten()\n",
    "\n",
    "\n",
    "print(\"=\" * 55)\n",
    "print(\" TASK 4: ANN from Scratch (NumPy)\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "# Train NumPy ANN\n",
    "numpy_ann = NumpyANN(input_size=5, h1=10, h2=8, output=1, lr=0.05)\n",
    "print(\"\\n Training for 100 epochs:\")\n",
    "losses = numpy_ann.train(X_train_scaled, y_train, epochs=100)\n",
    "\n",
    "# Evaluate NumPy ANN\n",
    "y_pred_numpy = numpy_ann.predict(X_test_scaled)\n",
    "numpy_acc = accuracy_score(y_test, y_pred_numpy)\n",
    "\n",
    "print(f\"\\n Final Comparison:\")\n",
    "print(f\" {'Model':<25} {'Accuracy':>12}\")\n",
    "print(f\" {'-'*40}\")\n",
    "print(f\" {'sklearn ANN':<25} {sklearn_accuracy*100:>11.2f}%\")\n",
    "print(f\" {'NumPy ANN (Scratch)':<25} {numpy_acc*100:>11.2f}%\")\n",
    "\n",
    "# Plot training loss curve\n",
    "plt.figure(figsize=(8, 4))\n",
    "plt.plot(range(1, 101), losses, color='#4C72B0', linewidth=2)\n",
    "plt.title('NumPy ANN — Training Loss over Epochs', fontweight='bold')\n",
    "plt.xlabel('Epoch')\n",
    "plt.ylabel('Binary Cross Entropy Loss')\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n PART 4 CONCLUSION:\")\n",
    "print(\" Both ANN models successfully predict bus delays.\")\n",
    "print(\" sklearn ANN uses optimized libraries (faster training).\")\n",
    "print(\" NumPy ANN demonstrates the math behind neural networks.\")\n",
    "print(\"=\" * 55)"
   ]
