    "# ============================================================\n",
    "# TASK 2: K-Means Clustering with k=3\n",
    "# Normalize → Cluster → Analyze → Elbow Method\n",
    "# ============================================================\n",
    "\n",
    "# Normalize features using StandardScaler\n",
    "features = traveller_df.columns.tolist()\n",
    "scaler5 = StandardScaler()\n",
    "X_scaled = scaler5.fit_transform(traveller_df)\n",
    "\n",
    "# Apply K-Means with k=3\n",
    "kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)\n",
    "traveller_df['Cluster'] = kmeans.fit_predict(X_scaled)\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\" TASK 2: K-Means Clustering (k=3)\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "# Cluster sizes\n",
    "print(\"\\n Cluster Sizes:\")\n",
    "for cluster_id in sorted(traveller_df['Cluster'].unique()):\n",
    " count = (traveller_df['Cluster'] == cluster_id).sum()\n",
    " print(f\" Cluster {cluster_id}: {count} travellers\")\n",
    "\n",
    "# Cluster profiles (average features per cluster)\n",
    "cluster_profile = traveller_df.groupby('Cluster')[features].mean().round(2)\n",
    "print(\"\\n Cluster Profiles (Average Feature Values):\")\n",
    "print(cluster_profile.to_string())\n",
    "\n",
    "# Label clusters based on feature values\n",
    "# Find which cluster has highest trips (business), lowest distance (commuter), etc.\n",
    "profile = traveller_df.groupby('Cluster').mean()\n",
    "\n",
    "# Business: highest loyalty + distance; Commuter: most trips + shortest distance; Family: rest\n",
    "business_cluster = profile['Loyalty_Points'].idxmax()\n",
    "commuter_cluster = profile['Avg_Journey_Distance'].idxmin()\n",
    "family_cluster = [c for c in [0,1,2]\n",
    " if c != business_cluster and c != commuter_cluster][0]\n",
    "\n",
    "cluster_labels = {\n",
    " business_cluster: 'Group A — Business Travellers ',\n",
    " family_cluster: 'Group B — Family Travellers ',\n",
    " commuter_cluster: 'Group C — Commuters ',\n",
    "}\n",
    "\n",
    "print(\"\\n Cluster Labels:\")\n",
    "for cid, label in cluster_labels.items():\n",
    " print(f\" Cluster {cid}: {label}\")\n",
    " print(f\" Trips/Month: {profile.loc[cid, 'Trips_Per_Month']:.1f} | \"\n",
    " f\"Distance: {profile.loc[cid, 'Avg_Journey_Distance']:.0f}km | \"\n",
    " f\"Loyalty: {profile.loc[cid, 'Loyalty_Points']:.0f}\")\n",
    "\n",
    "# Scatter plot: Trips vs Distance colored by cluster\n",
    "colors = {business_cluster: '#4C72B0',\n",
    " family_cluster: '#DD8452',\n",
    " commuter_cluster: '#55A868'}\n",
    "label_names = {business_cluster: 'Business', family_cluster: 'Family', commuter_cluster: 'Commuter'}\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 6))\n",
    "for cluster_id in sorted(traveller_df['Cluster'].unique()):\n",
    " subset = traveller_df[traveller_df['Cluster'] == cluster_id]\n",
    " ax.scatter(subset['Trips_Per_Month'], subset['Avg_Journey_Distance'],\n",
    " c=colors[cluster_id], label=label_names[cluster_id],\n",
    " alpha=0.7, s=50, edgecolors='white', linewidth=0.5)\n",
    "\n",
    "ax.set_xlabel('Trips Per Month', fontsize=12)\n",
    "ax.set_ylabel('Average Journey Distance (km)', fontsize=12)\n",
    "ax.set_title('PakTravel Traveller Clusters\\nTrips per Month vs Journey Distance',\n",
    " fontsize=13, fontweight='bold')\n",
    "ax.legend(fontsize=11)\n",
    "ax.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# ---- Elbow Method: Find optimal k ----\n",
    "print(\"\\n Elbow Method — Finding Optimal k:\")\n",
    "inertias = []\n",
    "k_range = range(1, 9)\n",
    "\n",
    "for k in k_range:\n",
    " km = KMeans(n_clusters=k, random_state=42, n_init=10)\n",
    " km.fit(X_scaled)\n",
    " inertias.append(km.inertia_)\n",
    " print(f\" k={k}: Inertia = {km.inertia_:.2f}\")\n",
    "\n",
    "# Plot elbow curve\n",
    "fig, ax = plt.subplots(figsize=(8, 5))\n",
    "ax.plot(k_range, inertias, 'bo-', markersize=8, linewidth=2)\n",
    "ax.axvline(x=3, color='red', linestyle='--', linewidth=2, label='Optimal k=3')\n",
    "ax.set_xlabel('Number of Clusters (k)', fontsize=12)\n",
    "ax.set_ylabel('Inertia (Within-Cluster Sum of Squares)', fontsize=12)\n",
    "ax.set_title('Elbow Method — Optimal k for PakTravel Clustering',\n",
    " fontsize=13, fontweight='bold')\n",
    "ax.legend(fontsize=11)\n",
    "ax.grid(True, alpha=0.3)\n",
    "ax.set_xticks(list(k_range))\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n Is k=3 Optimal?\")\n",
    "print(\" YES — The elbow curve shows the biggest drop in inertia at k=3.\")\n",
    "print(\" After k=3, adding more clusters gives diminishing returns.\")\n",
    "print(\" This matches our 3 expected traveller groups perfectly.\")\n",
    "\n",
    "print(\"\\n PART 5 CONCLUSION:\")\n",
    "print(\" K-Means with k=3 successfully identified 3 distinct traveller groups.\")\n",
    "print(\" Business Travellers: high loyalty, long distance, book ahead.\")\n",
    "print(\" Family Travellers: medium distance, book last minute, low loyalty.\")\n",
    "print(\" Commuters: short distance, frequent travel, minimal loyalty points.\")\n",
    "print(\" PakTravel can now offer personalized packages to each group!\")\n",
    "print(\"=\" * 60)"
   ]
