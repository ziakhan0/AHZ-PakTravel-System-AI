    "# ============================================================\n# TASK 2: Inference Rules using aima3\n# Demonstrates Modus Ponens, Hypothetical Syllogism, Modus Tollens\n# Each uses a FRESH PropDefiniteKB to show isolated reasoning\n# ============================================================\n\nprint(\"=\" * 65)\nprint(\"   TASK 2: Inference Rules\")\nprint(\"=\" * 65)\n\n# ---- MODUS PONENS ----\n# P = Speed_Above_Limit, Q = Challan_Issued\n# Premise 1: P (fact)\n# Premise 2: P ==> Q (rule)\n# Conclusion: Q\nprint(\"\\n  MODUS PONENS\")\nprint(\"-\" * 50)\nprint(\"   Statement 1 (P)   : Speed_Above_Limit = True\")\nprint(\"   Statement 2 (P=>Q): Speed_Above_Limit ==> Challan_Issued\")\nprint(\"   Logical Notation  : P, (P ==> Q) |-- Q\")\n\nmp_kb = PropDefiniteKB()            # Fresh KB for this inference\nmp_kb.tell(expr('Speed_Above_Limit ==> Challan_Issued'))   # Premise 2\nmp_kb.tell(expr('Speed_Above_Limit'))                       # Premise 1 (P)\n\nchallan_result = pl_fc_entails(mp_kb, expr('Challan_Issued'))  # Derive Q\nprint(f\"   Conclusion        : Challan_Issued = {challan_result}\")\nprint(f\"   Is Challan Issued? --> {'YES' if challan_result else 'NO'}\")\n\n\n# ---- HYPOTHETICAL SYLLOGISM ----\n# Chain: Speed_Above_Limit ==> Challan_Issued\n#        Challan_Issued & Not_Paid ==> License_Suspended\n#        License_Suspended & Still_Driving ==> Arrested\nprint(\"\\n  HYPOTHETICAL SYLLOGISM\")\nprint(\"-\" * 50)\nprint(\"   Rule 3:  Speed_Above_Limit         ==> Challan_Issued\")\nprint(\"   Rule 4:  Challan_Issued & Not_Paid  ==> License_Suspended\")\nprint(\"   Rule 5:  License_Suspended & Still_Driving ==> Arrested\")\nprint(\"   Chain:   Speeding => Challan => Suspension => ARREST\")\nprint()\n\nhs_kb = PropDefiniteKB()            # Fresh KB\nhs_kb.tell(expr('Speed_Above_Limit ==> Challan_Issued'))\nhs_kb.tell(expr('(Challan_Issued & Not_Paid) ==> License_Suspended'))\nhs_kb.tell(expr('(License_Suspended & Still_Driving) ==> Arrested'))\n\n# Tell Ahmed's relevant facts\nhs_kb.tell(expr('Speed_Above_Limit'))\nhs_kb.tell(expr('Not_Paid'))\nhs_kb.tell(expr('Still_Driving'))\n\n# Derive each step using pl_fc_entails\nstep1 = pl_fc_entails(hs_kb, expr('Challan_Issued'))\nstep2 = pl_fc_entails(hs_kb, expr('License_Suspended'))\nstep3 = pl_fc_entails(hs_kb, expr('Arrested'))\n\nprint(f\"   Step 1 (Rule 3): Challan_Issued       --> {'YES' if step1 else 'NO'}\")\nprint(f\"   Step 2 (Rule 4): License_Suspended    --> {'YES' if step2 else 'NO'}\")\nprint(f\"   Step 3 (Rule 5): Arrested             --> {'YES' if step3 else 'NO'}\")\nprint(\"   Hypothetical Syllogism: Speeding leads all the way to ARREST!\")\n\n\n# ---- MODUS TOLLENS ----\n# Premise 1: (License_Suspended & Still_Driving) ==> Arrested\n# Premise 2: ~Arrested (Bilal is NOT arrested)\n# Conclusion: ~(License_Suspended & Still_Driving)\n# i.e., either license was NOT suspended OR Bilal stopped driving\nprint(\"\\n  MODUS TOLLENS — Driver Bilal's Case\")\nprint(\"-\" * 50)\nprint(\"   Premise 1 (P=>Q) : (License_Suspended & Still_Driving) ==> Arrested\")\nprint(\"   Premise 2 (~Q)   : Bilal is NOT Arrested\")\nprint(\"   Logical Notation : (P ==> Q), ~Q |-- ~P\")\nprint(\"   Conclusion (~P)  : Bilal did NOT have License_Suspended\")\nprint(\"                      OR Bilal stopped driving\")\nprint()\n\n# Bilal's scenario — he paid his fines so license was NOT suspended\nbilal_arrested         = False  # Given: Bilal was NOT arrested\nbilal_paid_fines       = True   # Bilal paid fines on time\nbilal_lic_suspended    = not bilal_paid_fines  # False\n\n# By Modus Tollens: since ~Arrested, we know ~(License_Suspended & Still_Driving)\n# Python demonstration:\nprint(f\"   Bilal Arrested?           --> {'YES' if bilal_arrested      else 'NO'}\")\nprint(f\"   Bilal Paid Fines?         --> {'YES' if bilal_paid_fines    else 'NO'}\")\nprint(f\"   Bilal License Suspended?  --> {'YES' if bilal_lic_suspended else 'NO'}\")\nprint(\"   What saved Bilal: He paid his fines on time.\")\nprint(\"   No unpaid challan => No suspension => No arrest!\")\nprint(\"=\" * 65)\n"
