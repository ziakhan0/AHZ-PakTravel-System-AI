    "# ============================================================\n",
    "# TASK 2: Uniform Cost Search (UCS)\n",
    "# Finds the minimum total distance path between two cities\n",
    "# Uses a priority queue (min-heap) ordered by cumulative cost\n",
    "# ============================================================\n",
    "\n",
    "def ucs(graph, start, goal):\n",
    " \"\"\"\n",
    " Uniform Cost Search — finds shortest distance path.\n",
    " Returns: (path, total_distance, nodes_explored)\n",
    " \"\"\"\n",
    " # Priority queue: (cost, current_node, path_so_far)\n",
    " frontier = [(0, start, [start])]\n",
    " explored = set() # Track visited nodes\n",
    " nodes_explored = 0 # Counter for nodes explored\n",
    "\n",
    " while frontier:\n",
    " cost, node, path = heapq.heappop(frontier) # Pop lowest cost\n",
    "\n",
    " if node in explored:\n",
    " continue # Skip already explored nodes\n",
    "\n",
    " explored.add(node)\n",
    " nodes_explored += 1\n",
    "\n",
    " # Goal test — we found the destination!\n",
    " if node == goal:\n",
    " return path, cost, nodes_explored\n",
    "\n",
    " # Expand neighbors\n",
    " for neighbor, distance in graph.get(node, []):\n",
    " if neighbor not in explored:\n",
    " new_cost = cost + distance\n",
    " heapq.heappush(frontier, (new_cost, neighbor, path + [neighbor]))\n",
    "\n",
    " return None, float('inf'), nodes_explored # No path found\n",
    "\n",
    "\n",
    "def print_ucs_result(start, goal, graph):\n",
    " \"\"\"Run UCS and print formatted result for a journey.\"\"\"\n",
    " path, dist, nodes = ucs(graph, start, goal)\n",
    " print(f\"\\n Journey: {start} → {goal}\")\n",
    " print(f\" Path : {' → '.join(path)}\")\n",
    " print(f\" Distance : {dist} km\")\n",
    " print(f\" Stops : {len(path) - 2} intermediate stop(s)\")\n",
    " print(f\" Nodes Explored: {nodes}\")\n",
    " return path, dist, nodes\n",
    "\n",
    "\n",
    "print(\"=\" * 55)\n",
    "print(\" TASK 2: Uniform Cost Search (UCS) Results\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "# Test Journey 1: Ali's Journey — Karachi to Multan\n",
    "ucs_path1, ucs_dist1, ucs_nodes1 = print_ucs_result('Karachi', 'Multan', road_graph)\n",
    "\n",
    "# Test Journey 2: Karachi to Peshawar\n",
