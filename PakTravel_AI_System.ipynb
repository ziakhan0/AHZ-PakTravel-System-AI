    "# ============================================================\n",
    "# TASK 3: AC3 Arc Consistency\n",
    "# Reduces domains before backtracking by removing inconsistent values\n",
    "# For each pair of conflicting routes, remove buses that cause conflicts\n",
    "# ============================================================\n",
    "\n",
    "def ac3(routes, buses, conflicts):\n",
    " \"\"\"\n",
    " AC3 Arc Consistency Algorithm.\n",
    " Reduces bus domains for each route by eliminating values\n",
    " that would violate constraints with neighboring routes.\n",
    " Returns reduced domains dict.\n",
    " \"\"\"\n",
    " # Initialize full domain for each route\n",
    " domains = {route: list(buses) for route in routes}\n",
    "\n",
    " # Build arc queue: all conflicting (route1, route2) pairs\n",
    " queue = deque()\n",
    " for r1, r2 in conflicts:\n",
    " queue.append((r1, r2))\n",
    " queue.append((r2, r1))\n",
    "\n",
    " def revise(ri, rj):\n",
    " \"\"\"\n",
    " Remove values from domain[ri] that have no valid match in domain[rj].\n",
    " Returns True if domain[ri] was revised.\n",
    " \"\"\"\n",
    " revised = False\n",
    " for bus in list(domains[ri]):\n",
    " # Check if there exists any bus in rj's domain != bus\n",
    " # (since ri and rj conflict, they cannot share same bus)\n",
    " has_support = any(b != bus for b in domains[rj])\n",
    " if not has_support:\n",
    " domains[ri].remove(bus) # Remove inconsistent value\n",
    " revised = True\n",
    " return revised\n",
    "\n",
    " # Process all arcs\n",
    " while queue:\n",
    " ri, rj = queue.popleft()\n",
    " if revise(ri, rj):\n",
    " if not domains[ri]: # Empty domain = no solution\n",
    " return None\n",
    " # Re-add arcs involving ri\n",
    " for r1, r2 in conflicts:\n",
    " if r2 == ri and r1 != rj:\n",
    " queue.append((r1, ri))\n",
    " if r1 == ri and r2 != rj:\n",
    " queue.append((r2, ri))\n",
    "\n",
    " return domains\n",
    "\n",
    "\n",
    "# Run AC3\n",
    "domains_before = {r: list(BUSES) for r in route_names}\n",
    "domains_after = ac3(route_names, BUSES, CONFLICTS)\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\" TASK 3: AC3 Arc Consistency Results\")\n",
    "print(\"=\" * 60)\n",
    "print(f\"\\n{'Route':<6} {'Before AC3':>12} {'After AC3':>12} {'Reduction':>12}\")\n",
    "print(\"-\" * 50)\n",
    "for r in route_names:\n",
    " before = len(domains_before[r])\n",
    " after = len(domains_after[r]) if domains_after else 0\n",
    " red = before - after\n",
    " print(f\"{r:<6} {before:>12} {after:>12} {red:>12}\")\n",
    "\n",
    "# Run backtracking on AC3-reduced domains\n",
    "ac3_bt_solution, ac3_bt_calls = plain_backtracking(\n",
    " route_names, BUSES, CONFLICTS, domains=domains_after)\n",
    "ac3_mrv_solution, ac3_mrv_calls = mrv_backtracking(\n",
    " route_names, BUSES, CONFLICTS, domains=domains_after)\n",
    "\n",
    "print(f\"\\n{'Algorithm':<20} {'Calls':>10} {'Schedule Found':>15}\")\n",
    "print(\"-\" * 50)\n",
    "print(f\"{'Plain BT':<20} {bt_calls:>10} {'Yes' if bt_solution else 'No':>15}\")\n",
    "print(f\"{'MRV':<20} {mrv_calls:>10} {'Yes' if mrv_solution else 'No':>15}\")\n",
    "print(f\"{'MRV + AC3':<20} {ac3_mrv_calls:>10} {'Yes' if ac3_mrv_solution else 'No':>15}\")\n",
    "print(\"=\" * 60)"
   ]
