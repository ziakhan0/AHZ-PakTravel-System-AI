    "# ============================================================\n",
    "# TASK 1: Generate 400 Synthetic Traveller Records\n",
    "# Three natural groups:\n",
    "# Group A: Frequent Business Travellers (travel often, book ahead, long)\n",
    "# Group B: Occasional Family Travellers (rarely, last minute, medium)\n",
    "# Group C: Regular Short-Distance Commuters (often, short, low loyalty)\n",
    "# ============================================================\n",
    "\n",
    "def generate_traveller_data(n=400):\n",
    " \"\"\"\n",
    " Generate 400 traveller records with natural cluster structure.\n",
    " Each third of data represents one traveller group.\n",
    " \"\"\"\n",
    " n_each = n // 3\n",
    "\n",
    " # Group A: Frequent Business Travellers\n",
    " group_a = pd.DataFrame({\n",
    " 'Trips_Per_Month': np.random.randint(8, 15, n_each),\n",
    " 'Avg_Booking_Days': np.random.randint(10, 30, n_each),\n",
    " 'Avg_Journey_Distance': np.random.randint(400,700, n_each),\n",
    " 'Preferred_Time': np.random.randint(1, 3, n_each),\n",
    " 'Loyalty_Points': np.random.randint(3000,5000, n_each),\n",
    " 'Complaints_Filed': np.random.randint(0, 3, n_each),\n",
    " })\n",
    "\n",
    " # Group B: Occasional Family Travellers\n",
    " group_b = pd.DataFrame({\n",
    " 'Trips_Per_Month': np.random.randint(1, 4, n_each),\n",
    " 'Avg_Booking_Days': np.random.randint(0, 5, n_each),\n",
    " 'Avg_Journey_Distance': np.random.randint(200,500, n_each),\n",
    " 'Preferred_Time': np.random.randint(2, 4, n_each),\n",
    " 'Loyalty_Points': np.random.randint(500,2000, n_each),\n",
    " 'Complaints_Filed': np.random.randint(0, 8, n_each),\n",
    " })\n",
    "\n",
    " # Group C: Regular Short-Distance Commuters\n",
    " group_c = pd.DataFrame({\n",
    " 'Trips_Per_Month': np.random.randint(10, 15, n - 2*n_each),\n",
    " 'Avg_Booking_Days': np.random.randint(0, 5, n - 2*n_each),\n",
    " 'Avg_Journey_Distance': np.random.randint(100,250, n - 2*n_each),\n",
    " 'Preferred_Time': np.random.randint(1, 2, n - 2*n_each),\n",
    " 'Loyalty_Points': np.random.randint(0, 800, n - 2*n_each),\n",
    " 'Complaints_Filed': np.random.randint(0, 5, n - 2*n_each),\n",
    " })\n",
    "\n",
    " df = pd.concat([group_a, group_b, group_c], ignore_index=True)\n",
    " df = df.sample(frac=1, random_state=42).reset_index(drop=True) # Shuffle\n",
    " return df\n",
    "\n",
    "\n",
    "traveller_df = generate_traveller_data(400)\n",
