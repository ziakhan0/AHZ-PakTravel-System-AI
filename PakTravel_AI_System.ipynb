    "# ============================================================\n",
    "# TASK 4: Soft Constraints Scoring\n",
    "# Score = +2 for large bus on highway route\n",
    "# +1 for each bus operating <= 2 routes\n",
    "# ============================================================\n",
    "\n",
    "def score_schedule(solution):\n",
    " \"\"\"\n",
    " Calculate soft constraint score for a given bus schedule.\n",
    " +2 points: large bus (Bus1/2/3) on highway route (R1/R4/R5)\n",
    " +1 point : each bus that operates at most 2 routes\n",
    " \"\"\"\n",
    " score = 0\n",
    "\n",
    " # Soft constraint 1: Large buses on highway routes\n",
    " for route, bus in solution.items():\n",
    " if bus in LARGE_BUSES and route in HIGHWAY_ROUTES:\n",
    " score += 2\n",
    "\n",
    " # Soft constraint 2: No bus on more than 2 routes\n",
    " bus_usage = {}\n",
    " for bus in solution.values():\n",
    " bus_usage[bus] = bus_usage.get(bus, 0) + 1\n",
    "\n",
    " for bus, count in bus_usage.items():\n",
    " if count <= 2:\n",
    " score += 1\n",
    "\n",
    " return score\n",
    "\n",
    "\n",
    "# Score all found solutions\n",
    "solutions = [\n",
    " ('Plain BT', bt_solution),\n",
    " ('MRV', mrv_solution),\n",
    " ('MRV+AC3', ac3_mrv_solution),\n",
    "]\n",
    "\n",
    "best_solution = None\n",
    "best_score = -1\n",
    "best_name = ''\n",
    "\n",
    "print(\"=\" * 55)\n",
    "print(\" TASK 4: Soft Constraints — Best Schedule\")\n",
    "print(\"=\" * 55)\n",
    "print(f\"\\n{'Algorithm':<15} {'Score':>8}\")\n",
    "print(\"-\" * 25)\n",
    "for name, sol in solutions:\n",
    " if sol:\n",
    " s = score_schedule(sol)\n",
    " print(f\"{name:<15} {s:>8}\")\n",
    " if s > best_score:\n",
    " best_score = s\n",
    " best_solution = sol\n",
    " best_name = name\n",
    "\n",
    "print(f\"\\n Best Schedule: {best_name} (Score: {best_score})\")\n",
    "\n",
    "# Print final optimal schedule\n",
    "print(\"\\n Optimal Schedule:\")\n",
    "print(\"-\" * 65)\n",
    "print(f\" {'Route':<5} {'Description':<30} {'Bus':<8} {'Time':<6} {'Score'}\")\n",
